ANTHROPIC_API_KEY=your_api_key_here
DEFAULT_ENGINE=claude
CACHE_TTL_SECS=86400
SERVER_PORT=3000

# AI model selection — both fall back to DEFAULT_ENGINE if unset
AI_EXTRACTION_MODEL=claude-haiku-4-5-20251001
AI_REASONING_MODEL=claude-sonnet-4-6

# Optional — if set, Redis is used as a persistent shared cache layer.
# Start Redis with: docker compose up -d
REDIS_URL=redis://localhost:6379

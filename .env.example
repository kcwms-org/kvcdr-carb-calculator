ANTHROPIC_API_KEY=your_api_key_here
DEFAULT_ENGINE=claude
CACHE_TTL_SECS=86400
SERVER_PORT=3000

# Optional — if set, Redis is used as a persistent shared cache layer.
# Start Redis with: docker compose up -d
REDIS_URL=redis://localhost:6379

# Optional — DigitalOcean Spaces credentials for presigned image upload support.
# Without these, GET /presign and DELETE /upload/{key} return 503.
SPACES_ACCESS_KEY=your_spaces_access_key
SPACES_SECRET_KEY=your_spaces_secret_key
SPACES_REGION=nyc3
SPACES_BUCKET=s3-kvcdr
